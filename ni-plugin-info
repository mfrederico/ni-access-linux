#!/usr/bin/env python3
"""
ni-plugin-info stub — satisfies NI .deb package post-install scripts.
Writes minimal plugin metadata JSON to the output directory.

Usage: ni-plugin-info -s -j <output_dir> <plugin_path>
"""
import sys
import os
import json
import hashlib

def main():
    # Parse args: ni-plugin-info -s -j <output_dir> <plugin_path>
    args = [a for a in sys.argv[1:] if not a.startswith('-')]
    if len(args) < 2:
        print(f"Usage: {sys.argv[0]} -s -j <output_dir> <plugin_path>", file=sys.stderr)
        sys.exit(1)

    output_dir = args[0]
    plugin_path = args[1]

    if not os.path.exists(plugin_path):
        print(f"Plugin not found: {plugin_path}", file=sys.stderr)
        sys.exit(1)

    os.makedirs(output_dir, exist_ok=True)

    # Derive plugin name from path
    basename = os.path.basename(plugin_path)
    name = basename.replace('.vst3', '').replace('.so', '').replace('.dll', '')

    # Determine plugin type
    is_vst3 = plugin_path.endswith('.vst3') or os.path.isdir(plugin_path)

    # Generate a stable ID from the path
    plugin_id = hashlib.md5(name.encode()).hexdigest()

    info = {
        "name": name,
        "id": plugin_id,
        "path": os.path.abspath(plugin_path),
        "type": "vst3" if is_vst3 else "vst2",
        "arch": "x86_64-linux",
    }

    # Write JSON
    safe_name = name.replace(' ', '_').replace('/', '_')
    out_file = os.path.join(output_dir, f"{safe_name}.json")
    with open(out_file, 'w') as f:
        json.dump(info, f, indent=2)

    print(f"Registered: {name} -> {out_file}")


if __name__ == "__main__":
    main()
